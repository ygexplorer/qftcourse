# ──────────────────────────────────────────
# 规范场课程网站 — 环境变量模板
#
# 使用方法：复制此文件为 .env 并填入真实值
#   cp .env.example .env
# ──────────────────────────────────────────

# 安全密钥（生产环境必须更换为随机字符串！）
# 生成方法：python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-random-secret-string

# 调试模式
# 开发环境：True | 生产环境：False
DEBUG=True

# 允许的域名（逗号分隔，不含协议前缀）
# 开发环境：localhost,127.0.0.1
# 生产环境：yourdomain.com,www.yourdomain.com,你的服务器IP
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF 信任来源（逗号分隔，含协议前缀）
# 生产环境必须配置，否则表单提交会被拒绝
# 格式：https://yourdomain.com,https://www.yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# ──────────────────────────────────────────
# 数据库配置
# 开发环境：用 SQLite，无需配置以下项（自动使用 db.sqlite3）
# 生产环境：取消注释并填写 PostgreSQL 信息
# ──────────────────────────────────────────
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=qft_course
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432

# ──────────────────────────────────────────
# 上传文件存储路径
# 开发环境默认：项目根目录下的 media/
# 生产环境可修改为其他路径，如 /data/qft-course/media/
# ──────────────────────────────────────────
# MEDIA_ROOT=/data/qft-course/media/
