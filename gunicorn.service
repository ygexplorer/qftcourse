[Unit]
Description=Gunicorn instance for QFT Course
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/qftcourse
Environment="PATH=/home/ubuntu/qftcourse/venv/bin"
ExecStart=/home/ubuntu/qftcourse/venv/bin/gunicorn --workers 3 --bind 127.0.0.1:8000 wsgi:app
ExecReload=/bin/kill -s HUP $MAINPID
Restart=always

[Install]
WantedBy=multi-user.target
